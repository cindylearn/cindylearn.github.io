<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.suma.dashboard.update</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/suma/Downloads/cindylearn-pages/update_dashboard.py</string>
  </array>

  <!-- Every day at 8:00am -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>     <integer>8</integer>
    <key>Minute</key>   <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/suma/Downloads/cindylearn-pages/launchd_stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/suma/Downloads/cindylearn-pages/launchd_stderr.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
